# =============================================================================
# Classwork Studio - environment template
# Copy this file to `.env` and fill in your real keys.
# `.env` is in `.gitignore` — never commit your real keys to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Models
# -----------------------------------------------------------------------------
# Classwork Studio talks to any service that exposes an OpenAI-compatible
# Chat Completions API. Configure one (or many) of them below.
#
# ---- Multi-model mode (recommended) ---------------------------------------
# For each model you want to use, set:
#     LLM_<KEY>_API_KEY=...
#     LLM_<KEY>_BASE_URL=...        # optional; default https://api.openai.com/v1
#     LLM_<KEY>_MODEL=...           # optional; default = <KEY>
#     LLM_<KEY>_MAX_TOKENS=...      # optional; default 32768
#
# where <KEY> is any alphanumeric / underscore identifier — it will appear
# in the model's selector in the UI. Examples:
#
# LLM_PROD_API_KEY=sk-xxxxx
# LLM_PROD_BASE_URL=https://api.openai.com/v1
# LLM_PROD_MODEL=gpt-4o-mini
# LLM_PROD_MAX_TOKENS=16384
#
# LLM_FAST_API_KEY=sk-xxxxx
# LLM_FAST_BASE_URL=https://api.openai.com/v1
# LLM_FAST_MODEL=gpt-4o-mini
#
# ---- Single-model mode (simpler) ------------------------------------------
# If only one LLM_*_API_KEY pair is set, the app still works — that model
# becomes the only entry in MODEL_CONFIG and the default. Otherwise, the
# default is picked from MODEL_NAME below, or the lexicographically first
# configured key.
#
# =============================================================================

# Your default model key, must match one of the LLM_<KEY>_* keys above.
# MODEL_NAME=PROD

# -----------------------------------------------------------------------------
# Admin login
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# -----------------------------------------------------------------------------
# Flask / Server
# -----------------------------------------------------------------------------
# Optional Flask session secret (auto-generated if left empty).
SECRET_KEY=

# Listening port for wsgi.py (Waitress).
PORT=5000
